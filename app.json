{
  "expo": {
    "name": "El Maestrito",
    "slug": "talleres-app",
    "scheme": "elmaestrito",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elmaestrito.app"
    },
    "android": {
      "config": {
        "googleMaps": {
        "apiKey": "AIzaSyCDnSozdYNrdu1l8UlsZFuQ6M4EWn1aLMI"
        }
      },
      "package": "com.elmaestrito.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow El Maestrito to use your location at all times."
        }
      ],
      
      "expo-camera",
      "expo-notifications",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d51ccc8d-f202-4638-907c-72b3f8d65894"
      }
    }
  }
}
